# Get the ramdisk size from a file

PROG=$(basename "$0")

kernel=INSTALL
src=/usr/src
arch=$(uname -m)

usage() {
	printf >&2 'Usage: %s [-a <arch>] [-k <kernel>] [-s <srcdir>]\n' \
	    "${PROG}"
	exit 1
}

getsize() {
	set -f

	MDRSZ=$(grep MEMORY_DISK_ROOT_SIZE "$1") || return 1
	set -- ${MDRSZ}

	case "$2" in
	MEMORY_DISK_ROOT_SIZE=*[^0-9]*)
		return 1;;
	MEMORY_DISK_ROOT_SIZE=*)
		eval "$2";;
	*)
		return 1;;
	esac

	# should the following round down (as it does now), or up?
	printf '%dk\n' "$(( MEMORY_DISK_ROOT_SIZE / 2 ))"

	# leave exit status from printf, so we fail if output fails.
}

while getopts a:k:s: i
do
	case $i in
	a)	arch=$OPTARG;;
	k)	kernel=$OPTARG;;
	s)	src=$OPTARG;;
	*)
		usage;;
	esac
done
shift $((OPTIND - 1))

file=$src/sys/arch/$arch/conf/$kernel

if ! [ -f "$file" ]; then
	printf >&2 "%s: Can't open '%s'\\n" "${PROG}" "${file}"
	exit 1
fi

getsize "$file" || {
	printf >&2 '%s: Bad/missing MEMORY_DISK_ROOT_SIZE in %s\n' \
	    "${PROG}" "${file}"
	exit 1
}
