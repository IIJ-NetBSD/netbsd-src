.Nd datatypes for the CARRAY table-valued function
.Sh SYNOPSIS
.In sqlite3.h
.Fd #define SQLITE_CARRAY_INT32
.Fd #define SQLITE_CARRAY_INT64
.Fd #define SQLITE_CARRAY_DOUBLE
